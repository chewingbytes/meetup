# ── Soonest Webapp environment ───────────────────────────────────────────────
# Copy to .env.local and fill in. All NEXT_PUBLIC_* vars are exposed to the
# browser (safe — these are the same public values the Expo app ships).

# Backend API (the existing Express server)
NEXT_PUBLIC_API_BASE=https://server.hangoutstudios.com/api

# Self-hosted Supabase (anon key — public, used for realtime chat + presence)
NEXT_PUBLIC_SUPABASE_URL=https://supabase.hangoutstudios.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzY0NjkxMjAwLCJleHAiOjE5MjI0NTc2MDB9.RB4UMWyk4yUl0GvrbJ_B1f9u6AEar6prsBUTqN3ftWQ

# ── Server-side only (NOT exposed to browser) ────────────────────────────────
# Optional: enables the OpenAI Moderation pass on activity creation.
# If unset, the app falls back to the local high-risk word filter only.
OPENAI_API_KEY=
