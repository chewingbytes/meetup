---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "soonest — the action-first social network",
  description = "Stop performative flexing. Find like-minded people who get the grind. Drop a pin, filter the vibe, link up for real.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,400&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,400&display=swap"
      />
    </noscript>
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: "DM Sans", system-ui, sans-serif;
        background-color: #f4f1fa;
        color: #332f3a;
        overflow-x: hidden;
        line-height: 1.625;
      }

      :root {
        --canvas: #f4f1fa;
        --text-primary: #332f3a;
        --text-secondary: #635f69;
        --accent: #7c3aed;
        --accent-alt: #db2777;
        --shadow-card:
          10px 10px 12px rgba(160, 150, 180, 0.2),
          -5px -5px 12px rgba(255, 255, 255, 0.9),
          inset 6px 6px 12px rgba(139, 92, 246, 0.03),
          inset -6px -6px 12px rgba(255, 255, 255, 1);
        --shadow-button:
          10px 10px 22px rgba(139, 92, 246, 0.28),
          -6px -6px 14px rgba(255, 255, 255, 0.4),
          inset 3px 3px 7px rgba(255, 255, 255, 0.35),
          inset -3px -3px 7px rgba(0, 0, 0, 0.1);
        --shadow-button-hover:
          14px 14px 28px rgba(139, 92, 246, 0.38),
          -6px -6px 14px rgba(255, 255, 255, 0.4),
          inset 3px 3px 7px rgba(255, 255, 255, 0.35),
          inset -3px -3px 7px rgba(0, 0, 0, 0.1);
        --shadow-nav:
          8px 8px 20px rgba(160, 150, 180, 0.15),
          -6px -6px 16px rgba(255, 255, 255, 0.9),
          inset 2px 2px 6px rgba(255, 255, 255, 0.5),
          inset -2px -2px 6px rgba(0, 0, 0, 0.04);
      }

      @keyframes clay-float {
        0%,
        100% {
          transform: translateY(0) rotate(0deg);
        }
        50% {
          transform: translateY(-22px) rotate(2deg);
        }
      }
      @keyframes clay-float-alt {
        0%,
        100% {
          transform: translateY(0) rotate(0deg);
        }
        50% {
          transform: translateY(-16px) rotate(-2deg);
        }
      }
      @keyframes clay-breathe {
        0%,
        100% {
          transform: scale(1);
          box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.25);
        }
        50% {
          transform: scale(1.18);
          box-shadow: 0 0 0 6px rgba(16, 185, 129, 0.12);
        }
      }
      @keyframes fade-up {
        from {
          opacity: 0;
          transform: translateY(28px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
