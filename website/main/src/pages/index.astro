---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <!-- ── Fixed ambient blobs ── -->
  <div class="blobs" aria-hidden="true">
    <div class="blob blob-violet"></div>
    <div class="blob blob-pink"></div>
    <div class="blob blob-blue"></div>
    <div class="blob blob-green"></div>
  </div>

  <!-- ── Navigation ── -->
  <header class="nav-wrap">
    <nav class="nav">
      <div class="logo-lockup">
        <img src="/transparentlogo.png" alt="Soonest" class="logo-img" />
        <span class="logo-name">soonest</span>
      </div>
      <div class="nav-right">
        <a href="#waitlist" class="nav-btn">join waitlist</a>
      </div>
    </nav>
  </header>

  <!-- ── Hero ── -->
  <section class="hero">
    <div class="hero-inner">
      <div class="launch-badge">
        <span class="badge-pulse"></span>
        <span><span id="waitlist-count">0</span>+ people already waiting</span>
      </div>

      <h1 class="hero-headline">
        find your people,<br />
        <span class="gradient-text spontaneously">spontaneously.</span>
      </h1>

      <p class="hero-sub">
        browse and join nearby activities, and make real friends. Fill your day with people.
      </p>

      <div id="waitlist" class="form-card">
        <form id="form-hero" class="form-row">
          <input
            type="email"
            class="form-input"
            placeholder="your@email.com"
            required
            autocomplete="email"
          />
          <button type="submit" class="form-btn">
            get early access <span class="btn-arrow">→</span>
          </button>
        </form>
        <div
          id="success-hero"
          class="success-msg"
          role="alert"
          aria-live="polite"
        >
          🎉 you're on the list! we'll reach out before launch.
        </div>
      </div>

      <p class="hero-footnote">Sign up now to enjoy early access and perks.</p>
    </div>

    <!-- Notification bubbles -->
    <div class="hero-notif notif-1" aria-hidden="true">
      <img src="https://i.pravatar.cc/40?img=52" class="notif-ava" alt="" />
      <div class="notif-body">
        <strong>bryan</strong> wants to go bouldering 🧗 at 6pm
      </div>
    </div>
    <div class="hero-notif notif-2" aria-hidden="true">
      <img src="https://i.pravatar.cc/40?img=23" class="notif-ava" alt="" />
      <div class="notif-body">
        <strong>sarah</strong> joined dinner 🍽️ near you
      </div>
    </div>
    <div class="hero-notif notif-3" aria-hidden="true">
      <img src="https://i.pravatar.cc/40?img=44" class="notif-ava" alt="" />
      <div class="notif-body">
        <strong>maya</strong> wants a girls' night out! 🛍️
      </div>
    </div>
    <div class="hero-notif notif-4" aria-hidden="true">
      <img src="https://i.pravatar.cc/40?img=61" class="notif-ava" alt="" />
      <div class="notif-body">
        <strong>kai</strong> wants to go cafe hopping ☕
      </div>
    </div>

    <!-- MBTI pills -->
    <div
      class="hero-mbti mbti-p1"
      style="background:linear-gradient(135deg,#A78BFA,#7C3AED)"
      aria-hidden="true"
    >
      ENFP
    </div>
    <div
      class="hero-mbti mbti-p2"
      style="background:linear-gradient(135deg,#34D399,#10B981)"
      aria-hidden="true"
    >
      INFJ
    </div>
    <div
      class="hero-mbti mbti-p3"
      style="background:linear-gradient(135deg,#60A5FA,#3B82F6)"
      aria-hidden="true"
    >
      ESTJ
    </div>
    <div
      class="hero-mbti mbti-p4"
      style="background:linear-gradient(135deg,#FCD34D,#F59E0B)"
      aria-hidden="true"
    >
      ESTP
    </div>
    <div
      class="hero-mbti mbti-p5"
      style="background:linear-gradient(135deg,#F9A8D4,#DB2777)"
      aria-hidden="true"
    >
      INFP
    </div>

    <!-- Activity emoji pills -->
    <div class="hero-emoji e1" aria-hidden="true">🏀</div>
    <div class="hero-emoji e2" aria-hidden="true">☕</div>
    <div class="hero-emoji e3" aria-hidden="true">🛍️</div>
    <div class="hero-emoji e4" aria-hidden="true">📚</div>
    <div class="hero-emoji e5" aria-hidden="true">⚽</div>
    <div class="hero-emoji e6" aria-hidden="true">🎮</div>
    <div class="hero-emoji e7" aria-hidden="true">🎵</div>
    <div class="hero-emoji e8" aria-hidden="true">🏊</div>
    <div class="hero-emoji e9" aria-hidden="true">🎨</div>
  </section>

  <!-- ── Events section ── -->
  <section class="section">
    <div class="section-inner">
      <div class="section-head">
        <div class="section-badge">real plans</div>
        <h2 class="section-title">spend your day<br />with people</h2>
        <p class="section-sub">
