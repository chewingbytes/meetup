<script>
  /* ─────────────────────────────────────────
     Waitlist form submission
  ───────────────────────────────────────── */
  const SUPABASE_URL = "https://supabase.hangoutstudios.com";
  const SUPABASE_ANON_KEY =
    "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzY0NjkxMjAwLCJleHAiOjE5MjI0NTc2MDB9.RB4UMWyk4yUl0GvrbJ_B1f9u6AEar6prsBUTqN3ftWQ";

  async function submitToWaitlist(email: string): Promise<void> {
    const res = await fetch(`${SUPABASE_URL}/rest/v1/soonest_waitlist`, {
      method: "POST",
      headers: {
        apikey: SUPABASE_ANON_KEY,
        Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
        "Content-Type": "application/json",
        Prefer: "return=minimal",
      },
      body: JSON.stringify({ email }),
    });
    if (!res.ok) {
      const err = await res.text();
      if (res.status === 409 || err.includes("duplicate")) return;
      throw new Error(err || "Failed to submit");
    }
  }

  function setupForm(formId: string, successId: string) {
    const form = document.getElementById(formId) as HTMLFormElement | null;
    if (!form) return;
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = form.querySelector("button") as HTMLButtonElement;
      const emailInput = form.querySelector(
        'input[type="email"]',
      ) as HTMLInputElement;
      const email = emailInput.value.trim();
      btn.disabled = true;
      btn.innerHTML = "sending…";
      try {
        await submitToWaitlist(email);
        form.style.display = "none";
        const msg = document.getElementById(successId);
        if (msg) msg.style.display = "block";
      } catch {
        btn.disabled = false;
        btn.innerHTML = "try again";
        emailInput.setCustomValidity(
          "something went wrong — please try again.",
        );
        emailInput.reportValidity();
        emailInput.setCustomValidity("");
      }
    });
  }
  setupForm("form-hero", "success-hero");
  setupForm("form-cta", "success-cta");

  /* ─────────────────────────────────────────
     Waitlist count-up
  ───────────────────────────────────────── */
  const countEl = document.getElementById("waitlist-count");
  if (countEl) {
    const target = 200,
      duration = 1800,
      start = performance.now();
    const tick = (now: number) => {
      const p = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      countEl.textContent = String(Math.round(eased * target));
      if (p < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }

  /* ─────────────────────────────────────────
     Hero flip animation
  ───────────────────────────────────────── */
  const flipWords = [
    {
      text: "scale<br>your grind",
      color: "#7C3AED",
      font: "'Space Grotesk', sans-serif",
      style: "normal",
    },
    {
      text: "cut<br>toxicity",
      color: "#EA580C",
      font: "'Syne', sans-serif",
      style: "normal",
    },
    {
      text: "choose<br>friends wisely",
      color: "#F7868F",
      font: "'Lora', Georgia, serif",
      style: "italic",
    },
    {
      text: "lock in<br>together",
      color: "#6366F1",
      font: "'Plus Jakarta Sans', sans-serif",
      style: "normal",
    },
    {
      text: "never skip<br>a workout",
      color: "#059669",
      font: "'Nunito', sans-serif",
      style: "normal",
    },
    {
      text: "run a<br>sub-20 5k",
      color: "#DC2626",
      font: "'DM Mono', monospace",
      style: "normal",
    },
    {
      text: "talk over<br>coffee",
      color: "#B45309",
      font: "'Syne', sans-serif",
      style: "normal",
    },
    {
      text: "level up<br>your inner circle",
      color: "#DB2777",
      font: "'DM Sans', sans-serif",
      style: "normal",
    },
  ];

  const flipEl = document.getElementById("flip-word") as HTMLElement | null;
  if (flipEl) {
    let idx = 1; // first word is already set to [0]

    function doFlip() {
      // Exit
      flipEl!.style.transform = "translateY(-20px)";
      flipEl!.style.opacity = "0";

      setTimeout(() => {
        const w = flipWords[idx % flipWords.length];
        flipEl!.innerHTML = w.text;
        flipEl!.style.color = w.color;
        flipEl!.style.fontFamily = w.font;
        flipEl!.style.fontStyle = w.style;
        idx++;

        // Reset below, then transition in
        flipEl!.style.transition = "none";
        flipEl!.style.transform = "translateY(20px)";
        flipEl!.style.opacity = "0";

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            flipEl!.style.transition =
              "transform 0.45s cubic-bezier(0.25,0.46,0.45,0.94), opacity 0.45s ease";
            flipEl!.style.transform = "translateY(0)";
            flipEl!.style.opacity = "1";
          });
        });
      }, 380);
    }

    setInterval(doFlip, 2800);
  }
</script>

<!-- GSAP animations — classic inline script guarantees load order -->
<script is:inline>
  (function () {
    function loadScript(src, cb) {
      var s = document.createElement("script");
      s.src = src;
      s.onload = cb;
      s.onerror = function () {
        console.warn("[soonest] GSAP failed to load:", src);
      };
      document.head.appendChild(s);
    }

    function runAnimations() {
      var gsap = window.gsap;
      var ST = window.ScrollTrigger;
      if (!gsap || !ST) return;
      gsap.registerPlugin(ST);

      /* Manifesto — word-by-word reveal */
      var m = document.getElementById("manifesto-text");
      if (m) {
        var words = (m.textContent || "").trim().split(/\s+/);
        m.innerHTML = words
          .map(function (w, i) {
            var inner =
              i === words.length - 1
                ? w + '<span class="manifesto-ul"></span>'
                : w;
            var extra = /together/i.test(w)
              ? "font-style:italic;color:#7C3AED;"
              : "";
            return (
              '<span class="manifesto-word" style="display:inline-block;margin-right:0.25em;opacity:0;transform:translateY(24px);' +
              extra +
              '">' +
              inner +
              "</span>"
            );
          })
          .join("");
        var mTl = gsap.timeline({
          scrollTrigger: {
            trigger: "#manifesto-text",
            start: "top 80%",
            once: true,
          },
        });
        mTl.to(".manifesto-word", {
          opacity: 1,
          y: 0,
          stagger: 0.06,
          duration: 0.9,
          ease: "power3.out",
        });
        var ulAt = (words.length - 1) * 0.06 + 0.45;
        mTl.to(
          ".manifesto-ul",
          {
            width: "100%",
            duration: 0.55,
            ease: "power2.out",
          },
          ulAt,
        );
      }

      /* Problem cards */
      gsap.from(".problem-card", {
        opacity: 0,
        y: 60,
        stagger: 0.14,
        duration: 0.8,
        ease: "power2.out",
        scrollTrigger: {
          trigger: ".problem-grid",
          start: "top 82%",
          once: true,
        },
      });

      /* Map — surface settle + buildings rise */
      gsap.from("#map-stage .mm-surface", {
        opacity: 0,
        scale: 1.08,
        duration: 1.1,
        ease: "power2.out",
        scrollTrigger: { trigger: "#map-stage", start: "top 80%", once: true },
      });
      gsap.from("#map-stage .mm-blk", {
        opacity: 0,
        y: 12,
        scale: 0.88,
        stagger: { each: 0.035, from: "random" },
        duration: 0.5,
        ease: "power2.out",
        scrollTrigger: { trigger: "#map-stage", start: "top 80%", once: true },
      });

      /* Map chrome — topbar, you-marker, compass, scale */
      gsap.from(
        "#map-stage .mm-topbar, #map-stage .mm-you, #map-stage .mm-compass, #map-stage .mm-scale",
        {
          opacity: 0,
          y: 8,
          stagger: 0.08,
          delay: 0.25,
          duration: 0.6,
          ease: "power2.out",
          scrollTrigger: {
            trigger: "#map-stage",
            start: "top 78%",
            once: true,
          },
        },
      );

      /* Map pins — staggered pop-in */
      var pins = document.querySelectorAll(".mp");
      pins.forEach(function (pin, i) {
        gsap.fromTo(
          pin,
          { opacity: 0, scale: 0, y: 12 },
          {
            opacity: 1,
            scale: 1,
            y: 0,
            duration: 0.55,
            ease: "back.out(1.7)",
            delay: 0.4 + i * 0.16,
            scrollTrigger: {
              trigger: "#map-stage",
              start: "top 74%",
              once: true,
            },
          },
        );
      });

      /* HIW steps */
      gsap.from(".hiw-step", {
        opacity: 0,
        x: 30,
        stagger: 0.18,
        duration: 0.7,
        ease: "power2.out",
        scrollTrigger: { trigger: ".hiw-steps", start: "top 82%", once: true },
      });

      /* Universal section-head reveal */
      gsap.utils.toArray(".section-head").forEach(function (el) {
        gsap.from(el.children, {
          opacity: 0,
          y: 26,
          stagger: 0.1,
          duration: 0.7,
          ease: "power3.out",
          scrollTrigger: { trigger: el, start: "top 86%", once: true },
        });
      });

      /* Profiles — phone screens rise + fan, inner detail stagger */
      gsap.utils.toArray(".phone").forEach(function (ph, i) {
        var tl = gsap.timeline({
          scrollTrigger: {
            trigger: ".profiles-wrap",
            start: "top 78%",
            once: true,
          },
        });
        tl.from(
          ph,
          {
            opacity: 0,
            y: 90,
            rotateX: 16,
            scale: 0.9,
            duration: 0.9,
            ease: "power3.out",
            delay: i * 0.14,
            clearProps: "transform",
          },
          0,
        );
        var fill = ph.querySelector(".ps-ledger-fill");
        if (fill) {
          tl.from(
            fill,
            { width: 0, duration: 0.9, ease: "power2.out" },
            0.45 + i * 0.14,
          );
        }
        tl.from(
          ph.querySelectorAll(".ps-stat, .ps-feed-row"),
          {
            opacity: 0,
            y: 14,
            stagger: 0.06,
            duration: 0.5,
            ease: "power2.out",
          },
          0.5 + i * 0.14,
        );
      });

      /* Founder */
      gsap.from(".founder-profile, .founder-headline, .founder-body p", {
        opacity: 0,
        y: 30,
        stagger: 0.08,
        duration: 0.7,
        ease: "power2.out",
        scrollTrigger: {
          trigger: ".founder-wrap",
          start: "top 80%",
          once: true,
        },
      });

      /* Final CTA card */
      gsap.from(".cta-card", {
        opacity: 0,
        y: 50,
        scale: 0.96,
        duration: 0.85,
        ease: "power3.out",
        scrollTrigger: { trigger: ".cta-card", start: "top 86%", once: true },
      });

      /* Ambient blob parallax */
      gsap.to(".blob-violet", {
        yPercent: 14,
        ease: "none",
        scrollTrigger: {
          trigger: "body",
          start: "top top",
          end: "bottom bottom",
          scrub: true,
        },
      });
      gsap.to(".blob-pink", {
        yPercent: -12,
        ease: "none",
        scrollTrigger: {
          trigger: "body",
          start: "top top",
          end: "bottom bottom",
          scrub: true,
        },
      });

      /* Premium features (if present) */
      gsap.from(".prem-feat", {
        opacity: 0,
        y: 30,
        stagger: 0.12,
        duration: 0.6,
        ease: "power2.out",
        scrollTrigger: {
          trigger: ".prem-features",
          start: "top 82%",
          once: true,
        },
      });
    }

    loadScript(
      "https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js",
      function () {
        loadScript(
          "https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js",
          runAnimations,
        );
      },
    );
  })();
</script>
