---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import logo from "../assets/transparentlogo.png";

import avaBryan from "../assets/avatars/male/bryan.jpg";
import avaSarah from "../assets/avatars/female/sarah.jpeg";
import avaMaya from "../assets/avatars/female/maya.jpeg";
import avaKai from "../assets/avatars/male/kai.jpeg";

import avaM1 from "../assets/avatars/male/male.jpeg";
import avaM2 from "../assets/avatars/male/male2.jpeg";
import avaM3 from "../assets/avatars/male/male3.jpeg";
import avaM4 from "../assets/avatars/male/male4.jpeg";
import avaM5 from "../assets/avatars/male/male5.jpeg";
import avaF1 from "../assets/avatars/female/female.jpeg";
import avaF2 from "../assets/avatars/female/female2.jpeg";
import avaF3 from "../assets/avatars/female/female3.jpeg";
import avaF4 from "../assets/avatars/female/female4.jpeg";
import avaF5 from "../assets/avatars/female/female5.jpeg";

// ── Profile screen mock data ──
const profiles = [
  {
    img: avaBryan,
    name: "Bryan",
    age: 20,
    role: "Entrepreneur",
    city: "Singapore",
    accent: "#7C3AED",
    accentFrom: "#A78BFA",
    statusText: "deep in a codebase",
    statusEmoji: "💻",
    ledger: 96,
    ledgerNote: "showed up to 23 of 24 activities",
    stats: [
      ["12", "activities"],
      ["8", "day streak"],
    ],
    promptQ: "what i'm up for right now",
    promptA:
      "trying to run 2.4km under 11 minutes. looking for people with a similar goal to work towards it together.",
    tags: ["💻 TypeScript", "🎧 UK Garage", "🧗 Bouldering"],
    feed: [
      { ic: "💻", t: "Deep work sprint", s: "with 3 others · 2d ago" },
      { ic: "🍜", t: "Late supper run", s: "with 5 others · 5d ago" },
    ],
  },
  {
    img: avaF2,
    name: "Aisha",
    age: 23,
    role: "Product Designer",
    city: "United States",
    accent: "#DB2777",
    accentFrom: "#F9A8D4",
    statusText: "free after 6pm",
    statusEmoji: "☕",
    ledger: 88,
    ledgerNote: "showed up to 16 of 18 activities",
    stats: [
      ["9", "activities"],
      ["5", "day streak"],
    ],
    promptQ: "current hyper-fixation",
    promptA:
      "Muay Thai 3× a week and obsessing over motion design. Down to explore specialty coffee spots on weekends.",
    tags: ["🎨 Figma", "🥊 Muay Thai", "🎶 Afrobeats"],
    feed: [
      { ic: "☕", t: "Specialty coffee crawl", s: "with 4 others · 1d ago" },
      { ic: "🥊", t: "Muay Thai open mat", s: "with 6 others · 4d ago" },
    ],
  },
  {
    img: avaM3,
    name: "Marcus",
    age: 22,
    role: "Senior Software Engineer",
    city: "Germany",
    accent: "#059669",
    accentFrom: "#34D399",
    statusText: "looking for dinner",
    statusEmoji: "🍜",
    ledger: 93,
    ledgerNote: "showed up to 28 of 30 activities",
    stats: [
      ["15", "activities"],
      ["11", "day streak"],
    ],
    promptQ: "what i'm building",
    promptA:
      "Early-stage health-tech startup. Looking for dinner partners to go over ideas over good food.",
    tags: ["🚀 Startups", "🧗 Bouldering", "🎷 Jazz"],
    feed: [
      { ic: "🍜", t: "Founder dinner table", s: "with 5 others · 3d ago" },
      { ic: "🧗", t: "Bouldering session", s: "with 2 others · 6d ago" },
    ],
  },
];
---

<Layout
  title="soonest — the action-first social network"
  description="Stop performative flexing. Find like-minded people who get the grind. Drop a pin, filter the vibe, link up for real."
>
  <!-- ── Ambient blobs ── -->
  <div class="blobs" aria-hidden="true">
    <div class="blob blob-violet"></div>
    <div class="blob blob-pink"></div>
    <div class="blob blob-blue"></div>
    <div class="blob blob-green"></div>
  </div>

  <!-- ── Navigation ── -->
  <header class="nav-wrap">
    <nav class="nav">
      <div class="logo-lockup">
        <Image
          src={logo}
          alt="Soonest"
          class="logo-img"
          width={64}
          height={64}
        />
        <span class="logo-name">soonest</span>
      </div>
      <div class="nav-right">
        <a href="#waitlist" class="nav-btn">join waitlist</a>
      </div>
    </nav>
  </header>

  <!-- ── Hero ── -->
  <section class="hero">
    <div class="hero-inner">
      <div class="launch-badge">
        <span class="badge-pulse"></span>
        <span><span id="waitlist-count">0</span>+ people already waiting</span>
      </div>

      <div class="hero-headline-block">
        <h1 class="hero-headline">
          the <span class="irl-headline">irl</span> social network to
        </h1>
        <div class="flip-line" aria-live="polite" aria-atomic="true">
          <span id="flip-word" class="flip-word"
            >level up<br />your inner circle</span
          >
        </div>
      </div>

      <p class="hero-sub">
        stop just performatively flexing online. meet like-minded people who
        actually push you forward.
      </p>

      <div id="waitlist" class="form-card">
        <form id="form-hero" class="form-row">
          <input
            type="email"
            class="form-input"
            placeholder="your@email.com"
            required
            autocomplete="email"
          />
          <button type="submit" class="form-btn">
            get early access <span class="btn-arrow">→</span>
          </button>
        </form>
        <div
          id="success-hero"
          class="success-msg"
          role="alert"
          aria-live="polite"
        >
          🎉 you're on the list! we'll reach out before launch.
        </div>
      </div>

      <p class="hero-footnote">sign up now to enjoy early access and perks.</p>
    </div>

    <!-- Notification bubbles -->
    <div class="hero-notif notif-1" aria-hidden="true">
      <Image src={avaBryan} alt="" class="notif-ava" width={64} height={64} />
      <div class="notif-body">
        <strong>bryan</strong> wants to go bouldering 🧗 at 6pm
      </div>
    </div>
    <div class="hero-notif notif-2" aria-hidden="true">
      <Image src={avaSarah} alt="" class="notif-ava" width={64} height={64} />
      <div class="notif-body">
        <strong>sarah</strong> joined dinner 🍽️ near you
      </div>
    </div>
    <div class="hero-notif notif-3" aria-hidden="true">
      <Image src={avaMaya} alt="" class="notif-ava" width={64} height={64} />
      <div class="notif-body">
        <strong>maya</strong> dropped a coffee spot ☕
      </div>
    </div>
    <div class="hero-notif notif-4" aria-hidden="true">
      <Image src={avaKai} alt="" class="notif-ava" width={64} height={64} />
      <div class="notif-body">
        <strong>kai</strong> is deep in a codebase 💻
      </div>
    </div>

    <!-- Activity emoji floaters (no MBTI) -->
    <div class="hero-emoji e1" aria-hidden="true">🏀</div>
    <div class="hero-emoji e2" aria-hidden="true">☕</div>
    <div class="hero-emoji e3" aria-hidden="true">💻</div>
    <div class="hero-emoji e4" aria-hidden="true">📚</div>
    <div class="hero-emoji e5" aria-hidden="true">⚽</div>
    <div class="hero-emoji e6" aria-hidden="true">🎮</div>
    <div class="hero-emoji e7" aria-hidden="true">🎵</div>
    <div class="hero-emoji e8" aria-hidden="true">🧗</div>
    <div class="hero-emoji e9" aria-hidden="true">🎨</div>
  </section>

  <!-- ── Section 2: Manifesto + Problems ── -->
  <section class="section manifesto-section">
    <div class="manifesto-outer">
      <p class="manifesto-text" id="manifesto-text">
        'true connection is a byproduct of doing things <span
          style="font-style: italic; color: #7C3AED;">together</span
        >.'
      </p>
    </div>

    <!-- <div class="section-inner">
      <div class="problem-grid">
        <div class="problem-card">
          <div class="problem-num">01</div>
          <div class="problem-icon">🎭</div>
          <h3 class="problem-title">The Corporate Masquerade</h3>
          <p class="problem-body">
            Modern networking platforms force everyone to wear a performative
            mask. You connect based on resumes and inflated job titles, leading
            to forced, awkward coffee chats with zero real-life chemistry.
          </p>
        </div>
        <div class="problem-card">
          <div class="problem-num">02</div>
          <div class="problem-icon">🔗</div>
          <h3 class="problem-title">The Friendship Gap</h3>
          <p class="problem-body">
            Your current friends match your history, but they don't always match
            your daily energy. Sometimes you need a specific peer to keep you
            accountable on a late-night grind, and sometimes you just want
            someone who shares your exact niche music taste.
          </p>
        </div>
        <div class="problem-card">
          <div class="problem-num">03</div>
          <div class="problem-icon">📱</div>
          <h3 class="problem-title">The Clout Culture</h3>
          <p class="problem-body">
            Mainstream social apps have become hyper-superficial popularity
            contests. You optimize aesthetic profile grids, chase follower
            metrics, and perform for validation — curating an identity instead
            of just being human and linking up in real life.
          </p>
        </div>
      </div>
    </div> -->
  </section>

  <!-- ── Section 3: How It Works ── -->
  <section class="section hiw-section">
    <div class="section-inner">
      <div class="section-head">
        <div class="section-badge">how it works</div>
        <h2 class="section-title">actually meet people.</h2>
        <p class="section-sub">
          don't just add people to your connections list. browse, create and
          join activities with like-minded individuals with just a click of a
          button.
        </p>
      </div>

      <div class="hiw-layout">
        <!-- ── Map mock (redesigned) ── -->
        <div class="map-wrap" id="map-stage" aria-hidden="true">
          <!-- Base map surface -->
          <div class="mm-surface">
            <div class="mm-water"></div>
            <div class="mm-hwy mm-hwy-h"></div>
            <div class="mm-hwy mm-hwy-v"></div>
            <div class="mm-road mm-r-h1"></div>
            <div class="mm-road mm-r-h2"></div>
            <div class="mm-road mm-r-h3"></div>
            <div class="mm-road mm-r-v1"></div>
            <div class="mm-road mm-r-v2"></div>
            <div class="mm-local mm-l-h1"></div>
            <div class="mm-local mm-l-h2"></div>
            <div class="mm-local mm-l-h3"></div>
            <div class="mm-local mm-l-v1"></div>
            <div class="mm-local mm-l-v2"></div>
            <div class="mm-blk mm-b1 mm-lit"></div>
            <div class="mm-blk mm-b2"></div>
            <div class="mm-blk mm-b3"></div>
            <div class="mm-blk mm-b4 mm-lit"></div>
            <div class="mm-blk mm-b5 mm-lit"></div>
            <div class="mm-blk mm-b6"></div>
            <div class="mm-blk mm-b7 mm-lit"></div>
            <div class="mm-blk mm-b8"></div>
            <div class="mm-blk mm-b9 mm-lit"></div>
            <div class="mm-park"></div>

            <!-- Street labels -->
            <span class="mm-label" style="top:38%;left:8%">MARINA EXPY</span>
            <span class="mm-label mm-label-v" style="top:50%;left:37%"
              >ORCHARD RD</span
            >
            <span class="mm-label" style="top:18%;left:46%">CECIL ST</span>
            <span class="mm-label mm-water-label" style="bottom:8%;left:6%"
              >THE BAY</span
            >

            <div class="mm-grid"></div>

            <!-- Route from you → nearest pin -->
            <svg
              class="mm-route"
              viewBox="0 0 100 100"
              preserveAspectRatio="none"
            >
              <path
                d="M44 78 L44 52 Q44 44 36 44 L26 30"
                fill="none"
                stroke="rgba(124,58,237,0.55)"
                stroke-width="0.9"
                stroke-linecap="round"
                stroke-dasharray="2.4 2.4"></path>
            </svg>

            <!-- You-are-here marker -->
            <div class="mm-you" style="top:78%;left:44%">
              <span class="mm-you-acc"></span>
              <span class="mm-you-dot"></span>
            </div>
          </div>

          <!-- Top bar -->
          <div class="mm-topbar">
            <div class="mm-live-pill">
              <span class="mm-dot"></span>
              <span>Live</span>
            </div>
            <span class="mm-location">📍 Downtown District</span>
            <span class="mm-activity-count">12 active</span>
          </div>

          <!-- Compass -->
          <div class="mm-compass" aria-hidden="true">
            <span class="mm-compass-n">N</span>
            <span class="mm-compass-needle"></span>
          </div>

          <!-- Scale bar -->
          <div class="mm-scale" aria-hidden="true">
            <span class="mm-scale-bar"></span>
            <span class="mm-scale-txt">500 m</span>
          </div>

          <!-- Pin: Study -->
          <div class="mp" style="--c:#7C3AED;--gfrom:#A78BFA;top:22%;left:26%">
            <div class="mp-ring"></div>
            <div class="mp-icon">💻</div>
            <div class="mp-stem"></div>
            <div class="mp-card">
              <span class="mp-cat" style="color:#A78BFA">Study</span>
              <div class="mp-name">Deep-diving a codebase</div>
              <div class="mp-meta">10 PM · 2 going</div>
              <div class="mp-avs">
                <div class="mp-av" style="background:#A78BFA">J</div>
                <div class="mp-av" style="background:#7C3AED">R</div>
              </div>
            </div>
          </div>

          <!-- Pin: Coffee -->
          <div class="mp" style="--c:#D97706;--gfrom:#FCD34D;top:50%;left:55%">
            <div class="mp-ring"></div>
            <div class="mp-icon">☕</div>
            <div class="mp-stem"></div>
            <div class="mp-card mp-card-left">
              <span class="mp-cat" style="color:#FCD34D">Coffee</span>
              <div class="mp-name">Specialty coffee run</div>
              <div class="mp-meta">9 PM · 4 going</div>
              <div class="mp-avs">
                <div class="mp-av" style="background:#D97706">S</div>
                <div class="mp-av" style="background:#F59E0B">M</div>
                <div class="mp-av" style="background:#FCD34D;color:#78350F">
                  +2
                </div>
              </div>
            </div>
          </div>

          <!-- Pin: Run -->
          <div class="mp" style="--c:#059669;--gfrom:#34D399;top:68%;left:16%">
            <div class="mp-ring"></div>
            <div class="mp-icon">🏃</div>
            <div class="mp-stem"></div>
            <div class="mp-card">
              <span class="mp-cat" style="color:#34D399">Sports</span>
              <div class="mp-name">Late-night run loop</div>
              <div class="mp-meta">11 PM · 3 going</div>
            </div>
          </div>

          <!-- Pin: Supper -->
          <div class="mp" style="--c:#DB2777;--gfrom:#F9A8D4;top:30%;left:64%">
            <div class="mp-ring"></div>
            <div class="mp-icon">🍜</div>
            <div class="mp-stem"></div>
            <div class="mp-card mp-card-left">
              <span class="mp-cat" style="color:#F9A8D4">Food</span>
              <div class="mp-name">Cheap supper loop</div>
              <div class="mp-meta">12 AM · 5 going</div>
            </div>
          </div>

          <!-- Pin: Boulder -->
          <div class="mp" style="--c:#2563EB;--gfrom:#93C5FD;top:12%;left:58%">
            <div class="mp-ring"></div>
            <div class="mp-icon">🧗</div>
            <div class="mp-stem"></div>
            <div class="mp-card mp-card-below">
              <span class="mp-cat" style="color:#93C5FD">Sports</span>
              <div class="mp-name">Bouldering session</div>
              <div class="mp-meta">7 PM · 6 going</div>
            </div>
          </div>

          <!-- Filter bar -->
          <!-- <div class="mm-fbar">
            <button class="mm-chip mm-chip-on">All</button>
            <button class="mm-chip">☕</button>
            <button class="mm-chip">💻</button>
            <button class="mm-chip">🏃</button>
            <button class="mm-chip">🍜</button>
          </div> -->
        </div>

        <!-- ── Steps ── -->
        <div class="hiw-steps">
          <div class="hiw-step">
            <div class="step-num">01</div>
            <div class="step-content">
              <h3 class="step-title">drop an activity</h3>
              <p class="step-kicker">takes 10 seconds.</p>
              <p class="step-body">
                training for a marathon? grinding late-night deep work? trying
                to hit a new PR? or just want to grab a good dinner with good
                people? drop a live pin on the map with the exact vibe or target
                you’re chasing right now. find your parallel accountability
                partner and cross the finish line together.
              </p>
            </div>
          </div>

          <div class="hiw-step">
            <div class="step-num">02</div>
            <div class="step-content">
              <h3 class="step-title">choose who you want to meet</h3>
              <p class="step-kicker">frictionless entry.</p>
              <p class="step-body">
                choose exactly who you want to cross paths with filters straight
                down to your interests and passions.
              </p>
            </div>
          </div>

          <div class="hiw-step">
            <div class="step-num">03</div>
            <div class="step-content">
              <h3 class="step-title">check the ledger</h3>
              <p class="step-kicker">zero flake zone.</p>
              <p class="step-body">
                every profile features an automated reliability score based on
                actual meetup attendance. we filter out the talkers so you only
                link up with people who actually show up.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Section 4: Profile Mocks (vertical phone screens) ── -->
  <section class="section profiles-section">
    <div class="section-inner">
      <div class="section-head">
        <div class="section-badge">the soonest profile</div>
        <h2 class="section-title">no resume. no follower count.</h2>
        <p class="section-sub">
          just who you are, what you're working towards, and what you're down to
          do — right now.
        </p>
      </div>

      <div class="profiles-wrap">
        {
          profiles.map((p, i) => (
            <article
              class={`phone pc-${i + 1}`}
              style={`--pc:${p.accent};--pc-from:${p.accentFrom}`}
            >
              <div class="phone-glow" aria-hidden="true" />
              <div class="phone-screen">
                <div class="ps-status">
                  <span class="ps-time">9:41</span>
                  <span class="ps-status-ic">
                    <svg width="17" height="11" viewBox="0 0 17 11" fill="none">
                      <rect
                        x="0"
                        y="7"
                        width="3"
                        height="4"
                        rx="1"
                        fill="currentColor"
                      />
                      <rect
                        x="4.5"
                        y="5"
                        width="3"
                        height="6"
                        rx="1"
                        fill="currentColor"
                      />
                      <rect
                        x="9"
                        y="2.5"
                        width="3"
                        height="8.5"
                        rx="1"
                        fill="currentColor"
                      />
                      <rect
                        x="13.5"
                        y="0"
                        width="3"
                        height="11"
                        rx="1"
                        fill="currentColor"
                        opacity="0.4"
                      />
                    </svg>
                    <svg width="15" height="11" viewBox="0 0 15 11" fill="none">
                      <path
                        d="M7.5 10.2 1 4.1a9 9 0 0 1 13 0L7.5 10.2Z"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.3"
                        opacity="0.35"
                      />
                      <path
                        d="M7.5 10.2 3.7 6.5a5.4 5.4 0 0 1 7.6 0L7.5 10.2Z"
                        fill="currentColor"
                      />
                    </svg>
                    <svg width="24" height="12" viewBox="0 0 24 12" fill="none">
                      <rect
                        x="0.5"
                        y="0.5"
                        width="20"
                        height="11"
                        rx="3"
                        stroke="currentColor"
                        opacity="0.45"
                      />
                      <rect
                        x="2"
                        y="2"
                        width="15"
                        height="8"
                        rx="1.6"
                        fill="currentColor"
                      />
                      <rect
                        x="21.5"
                        y="3.5"
                        width="1.8"
                        height="5"
                        rx="0.9"
                        fill="currentColor"
                        opacity="0.45"
                      />
                    </svg>
                  </span>
                </div>

                <div class="ps-scroll">
                  <div class="ps-id">
                    <div class="ps-ava-wrap">
                      <Image
                        src={p.img}
                        alt={p.name}
                        class="ps-ava"
                        width={160}
                        height={160}
                      />
                      <span class="ps-ava-status" />
                    </div>
                    <div class="ps-id-text">
                      <div class="ps-name-row">
                        <h3 class="ps-name">
                          {p.name}, {p.age}
                        </h3>
                        <svg
                          class="ps-verified"
                          width="16"
                          height="16"
                          viewBox="0 0 16 16"
                          fill="none"
                        >
                          <path
                            d="M8 0.8l1.9 1.4 2.3-.2.9 2.2 2 1.2-.8 2.2.8 2.2-2 1.2-.9 2.2-2.3-.2L8 15.2 6.1 13.8l-2.3.2-.9-2.2-2-1.2.8-2.2-.8-2.2 2-1.2.9-2.2 2.3.2L8 0.8Z"
                            fill="var(--pc)"
                          />
                          <path
                            d="M5.4 8.1l1.7 1.7 3.5-3.6"
                            stroke="#fff"
                            stroke-width="1.4"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            fill="none"
                          />
                        </svg>
                      </div>
                      <p class="ps-role">
                        {p.role} · {p.city}
                      </p>
                    </div>
                  </div>

                  <div class="ps-ledger">
                    <div class="ps-ledger-top">
                      <span class="ps-ledger-label">⚡ Reliability Ledger</span>
                      <span class="ps-ledger-pct">{p.ledger}%</span>
                    </div>
                    <div class="ps-ledger-bar">
                      <span
                        class="ps-ledger-fill"
                        style={`width:${p.ledger}%`}
                      />
                    </div>
                    <p class="ps-ledger-note">{p.ledgerNote}</p>
                  </div>

                  <div class="ps-stats">
                    {p.stats.map((s) => (
                      <div class="ps-stat">
                        <b>{s[0]}</b>
                        <span>{s[1]}</span>
                      </div>
                    ))}
                  </div>

                  <div class="ps-block">
                    <span class="ps-block-q">{p.promptQ}</span>
                    <p class="ps-block-a">{p.promptA}</p>
                  </div>

                  <div class="ps-tags">
                    {p.tags.map((t) => (
                      <span class="ps-tag">{t}</span>
                    ))}
                  </div>

                  <div class="ps-feed">
                    <span class="ps-feed-h">recent meetups</span>
                    {p.feed.map((f) => (
                      <div class="ps-feed-row">
                        <span class="ps-feed-ic">{f.ic}</span>
                        <div class="ps-feed-txt">
                          <b>{f.t}</b>
                          <span>{f.s}</span>
                        </div>
