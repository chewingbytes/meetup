  <!-- ── Day Timeline ── -->
  <section class="section">
    <div class="section-inner">
      <div class="section-head">
        <div class="section-badge">your day</div>
        <h2 class="section-title">here's what your<br />day could look like</h2>
        <p class="section-sub">
          alex woke up with no plans. by 10pm, she had lived a whole day with
          people she actually clicked with.
        </p>
      </div>

      <div class="timeline">
        <div class="tl-item">
          <div class="tl-time">7:00 am</div>
