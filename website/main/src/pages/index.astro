  <!-- ── Final CTA ── -->
  <section class="section cta-section">
    <div class="section-inner">
      <div class="cta-card">
        <div class="cta-blob cta-blob-1" aria-hidden="true"></div>
        <div class="cta-blob cta-blob-2" aria-hidden="true"></div>
        <div class="cta-content">
          <h2 class="cta-title">be first through the door.</h2>
          <p class="cta-sub">
            early members get priority access, exclusive in-app badges, and the
            chance to shape what soonest becomes.
          </p>

          <form id="form-cta" class="form-row form-row-dark">
            <input
              type="email"
              class="form-input form-input-dark"
              placeholder="your@email.com"
              required
              autocomplete="email"
            />
            <button type="submit" class="form-btn form-btn-white">
              join waitlist
