      0 40px 100px rgba(0, 0, 0, 0.6),
      0 0 0 1px rgba(255, 255, 255, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }
  /* vignette for depth */
  .map-wrap::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 5;
    background: radial-gradient(
      120% 90% at 50% 40%,
      transparent 55%,
      rgba(0, 0, 0, 0.45) 100%
    );
  }
  @media (min-width: 860px) {
    .hiw-layout {
      align-items: center;
    }
  }
  .mm-surface {
    position: absolute;
    inset: 0;
  }

  /* Water — organic bay shape, bottom-left */
  .mm-water {
    position: absolute;
    bottom: -18%;
    left: -8%;
    width: 56%;
    height: 58%;
    background: #071422;
    border-radius: 44% 56% 48% 36% / 52% 44% 56% 48%;
    box-shadow:
      inset 0 0 60px rgba(10, 50, 120, 0.18),
      inset 0 0 20px rgba(10, 70, 160, 0.1);
  }

  /* Expressway — widest, dashed center line */
  .mm-hwy {
    position: absolute;
  }
  .mm-hwy-h {
    top: 40%;
    left: 0;
    right: 0;
    height: 26px;
    background: linear-gradient(180deg, #1a2c48, #1e3354 50%, #1a2c48);
  }
  .mm-hwy-h::after {
    content: "";
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    left: 0;
    right: 0;
    height: 1.5px;
    background: repeating-linear-gradient(
      90deg,
      rgba(255, 220, 60, 0.28) 0,
      rgba(255, 220, 60, 0.28) 16px,
      transparent 16px,
      transparent 28px
    );
  }
  .mm-hwy-v {
    left: 38%;
    top: 0;
    bottom: 0;
    width: 22px;
    background: linear-gradient(90deg, #1a2c48, #1e3354 50%, #1a2c48);
  }
  .mm-hwy-v::after {
    content: "";
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    top: 0;
    bottom: 0;
    width: 1.5px;
    background: repeating-linear-gradient(
      0deg,
      rgba(255, 220, 60, 0.28) 0,
      rgba(255, 220, 60, 0.28) 16px,
      transparent 16px,
      transparent 28px
    );
  }

  /* Major arterials */
  .mm-road {
    position: absolute;
    background: #122038;
  }
  .mm-r-h1 {
    top: 20%;
    left: 0;
    right: 0;
    height: 13px;
  }
  .mm-r-h2 {
    top: 62%;
    left: 0;
    right: 0;
    height: 13px;
  }
  .mm-r-h3 {
    top: 80%;
    left: 38%;
    right: 0;
    height: 10px;
  }
  .mm-r-v1 {
    left: 18%;
    top: 0;
    bottom: 0;
    width: 12px;
  }
  .mm-r-v2 {
    left: 62%;
    top: 0;
    bottom: 40%;
    width: 12px;
  }

  /* Minor / local streets */
  .mm-local {
    position: absolute;
    background: #0e1a2c;
  }
  .mm-l-h1 {
    top: 12%;
    left: 38%;
    right: 0;
    height: 7px;
  }
  .mm-l-h2 {
    top: 52%;
    left: 0;
    right: 62%;
    height: 7px;
  }
  .mm-l-h3 {
    top: 72%;
    left: 18%;
    right: 0;
    height: 7px;
  }
  .mm-l-v1 {
    left: 50%;
    top: 40%;
    bottom: 0;
    width: 7px;
  }
  .mm-l-v2 {
    left: 76%;
    top: 0;
    bottom: 40%;
    width: 7px;
  }

  /* Building blocks */
  .mm-blk {
    position: absolute;
    border-radius: 4px;
    background: #0c1828;
    box-shadow:
      inset 0 0 0 0.5px rgba(255, 255, 255, 0.04),
      inset 0 6px 14px rgba(0, 0, 0, 0.35);
    /* faint building windows */
    background-image: radial-gradient(
      rgba(120, 150, 200, 0.1) 0.6px,
      transparent 0.6px
    );
    background-size: 6px 6px;
    background-position: 3px 3px;
  }
  /* Lit buildings — warm windows */
  .mm-lit {
    background-image: radial-gradient(
      rgba(255, 214, 140, 0.22) 0.7px,
      transparent 0.9px
    );
    background-size: 7px 7px;
    box-shadow:
      inset 0 0 0 0.5px rgba(255, 200, 120, 0.06),
      inset 0 6px 14px rgba(0, 0, 0, 0.35),
      0 0 18px rgba(255, 190, 90, 0.04);
  }
  .mm-b1 {
    top: 3%;
    left: 2%;
    width: 13%;
    height: 14%;
    background: #0d1b2c;
  }
  .mm-b2 {
    top: 3%;
    left: 20%;
    width: 9%;
    height: 14%;
  }
  .mm-b3 {
    top: 22%;
    left: 2%;
    width: 13%;
    height: 14%;
    background: #0b1625;
  }
  .mm-b4 {
    top: 22%;
    left: 20%;
    width: 9%;
    height: 9%;
  }
  .mm-b5 {
    top: 3%;
    left: 42%;
    width: 16%;
    height: 14%;
  }
  .mm-b6 {
    top: 3%;
    left: 66%;
    width: 12%;
    height: 9%;
    background: #0d1b2c;
  }
  .mm-b7 {
    top: 3%;
    left: 80%;
    width: 17%;
    height: 14%;
  }
  .mm-b8 {
    top: 14%;
    left: 66%;
    width: 30%;
    height: 22%;
    background: #0b1625;
  }
  .mm-b9 {
    top: 44%;
    left: 42%;
    width: 16%;
    height: 14%;
  }

  /* Park — dotted texture */
  .mm-park {
    position: absolute;
    top: 3%;
    right: 3%;
    width: 14%;
    height: 24%;
    border-radius: 8px;
    overflow: hidden;
    background-color: rgba(16, 185, 129, 0.04);
    background-image: radial-gradient(
      circle,
      rgba(16, 185, 129, 0.2) 1px,
      transparent 1px
    );
    background-size: 7px 7px;
    border: 1px solid rgba(16, 185, 129, 0.12);
  }

  /* Grid overlay */
  .mm-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(40, 70, 130, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(40, 70, 130, 0.05) 1px, transparent 1px);
    background-size: 30px 30px;
  }

  /* Street labels */
  .mm-label {
    position: absolute;
    font-family: "DM Mono", monospace;
    font-size: 0.5rem;
    letter-spacing: 0.14em;
    color: rgba(150, 175, 220, 0.32);
    white-space: nowrap;
    pointer-events: none;
    text-transform: uppercase;
  }
  .mm-label-v {
    transform: rotate(90deg);
    transform-origin: left center;
  }
  .mm-water-label {
    color: rgba(90, 140, 220, 0.4);
    font-style: italic;
    letter-spacing: 0.18em;
  }

  /* Route line — flowing dashes */
  .mm-route {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 6;
    overflow: visible;
  }
  .mm-route path {
    animation: mm-route-flow 1.1s linear infinite;
  }
  @keyframes mm-route-flow {
    to {
      stroke-dashoffset: -9.6;
    }
  }

  /* You-are-here */
  .mm-you {
    position: absolute;
    z-index: 8;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }
  .mm-you-dot {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: #3b82f6;
    border: 2.5px solid #fff;
    transform: translate(-50%, -50%);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
  }
  .mm-you-acc {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(59, 130, 246, 0.28) 0%,
      rgba(59, 130, 246, 0.06) 55%,
      transparent 70%
    );
    border: 1px solid rgba(59, 130, 246, 0.25);
    transform: translate(-50%, -50%);
    animation: mp-ring-pulse 2.8s ease-in-out infinite;
  }

  /* Compass */
  .mm-compass {
    position: absolute;
    top: 56px;
    right: 14px;
    z-index: 10;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(6, 10, 22, 0.8);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mm-compass-n {
    position: absolute;
    top: 3px;
    font-family: "Nunito", sans-serif;
    font-weight: 800;
    font-size: 0.46rem;
    color: rgba(255, 255, 255, 0.7);
  }
  .mm-compass-needle {
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-bottom: 11px solid #db2777;
    transform: translateY(-2px);
    filter: drop-shadow(0 0 3px rgba(219, 39, 119, 0.5));
  }

  /* Scale bar */
  .mm-scale {
    position: absolute;
    bottom: 14px;
    left: 14px;
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: 3px;
    align-items: flex-start;
  }
  .mm-scale-bar {
    width: 48px;
    height: 5px;
    border-bottom: 1.5px solid rgba(255, 255, 255, 0.4);
    border-left: 1.5px solid rgba(255, 255, 255, 0.4);
    border-right: 1.5px solid rgba(255, 255, 255, 0.4);
  }
  .mm-scale-txt {
    font-family: "DM Mono", monospace;
    font-size: 0.5rem;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.05em;
  }

  /* Top bar */
  .mm-topbar {
    position: absolute;
    top: 14px;
    left: 14px;
    right: 14px;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .mm-live-pill {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(6, 10, 22, 0.84);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 100px;
    padding: 5px 13px;
    font-family: "Nunito", sans-serif;
    font-weight: 800;
    font-size: 0.74rem;
    color: rgba(255, 255, 255, 0.85);
  }
  .mm-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #10b981;
    flex-shrink: 0;
    animation: clay-breathe 2s ease-in-out infinite;
  }
  .mm-location {
    background: rgba(6, 10, 22, 0.75);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 100px;
    padding: 5px 13px;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.42);
    font-family: "DM Sans", sans-serif;
  }
  .mm-activity-count {
    margin-left: auto;
    background: rgba(124, 58, 237, 0.22);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(124, 58, 237, 0.3);
    border-radius: 100px;
    padding: 5px 13px;
    font-size: 0.72rem;
    font-weight: 700;
    color: #c4b5fd;
    font-family: "Nunito", sans-serif;
  }

  /* Pins */
  .mp {
    position: absolute;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    transform-origin: bottom center;
    opacity: 0; /* GSAP sets to 1 */
  }
  /* Pulse ring uses CSS var --c from the parent .mp inline style */
  .mp-ring {
    position: absolute;
    top: -6px;
    left: 50%;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--c) 0%, transparent 66%);
    opacity: 0.22;
    transform: translate(-50%, 0);
    animation: mp-ring-pulse 2.4s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes mp-ring-pulse {
    0%,
    100% {
      transform: translate(-50%, 0) scale(1);
      opacity: 0.22;
    }
    50% {
      transform: translate(-50%, 0) scale(1.75);
      opacity: 0;
    }
  }
  /* Circle icon */
  .mp-icon {
    position: relative;
    z-index: 2;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(145deg, var(--gfrom), var(--c));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    line-height: 1;
    box-shadow:
      0 5px 20px rgba(0, 0, 0, 0.55),
      0 0 0 2.5px rgba(255, 255, 255, 0.15);
    transition:
      transform 0.22s ease,
      box-shadow 0.22s ease;
  }
  .mp:hover .mp-icon {
    transform: scale(1.12) translateY(-3px);
    box-shadow:
      0 12px 30px rgba(0, 0, 0, 0.65),
      0 0 0 2.5px rgba(255, 255, 255, 0.22);
  }
  /* Teardrop pointer */
  .mp-stem {
    width: 0;
    height: 0;
    z-index: 2;
    border-left: 6px solid transparent;
    border-right: 6px solid transparent;
    border-top: 9px solid var(--c);
    margin-top: -1px;
    filter: drop-shadow(0 3px 5px rgba(0, 0, 0, 0.4));
  }
  /* Tooltip card */
  .mp-card {
    position: absolute;
    z-index: 20;
    bottom: calc(100% + 14px);
    left: 50%;
    transform: translateX(-50%) translateY(5px);
    background: rgba(6, 10, 22, 0.96);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 18px;
    padding: 13px 16px;
    min-width: 175px;
    width: max-content;
    max-width: 215px;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.55);
  }
  .mp:hover .mp-card {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  /* Align to right side for right-edge pins */
  .mp-card-left {
    left: auto;
    right: calc(100% + 12px);
    bottom: 0;
    top: auto;
    transform: translateX(0) translateY(5px);
  }
  .mp:hover .mp-card-left {
    transform: translateX(0) translateY(0);
  }
  /* Below for top-edge pins */
  .mp-card-below {
    bottom: auto;
    top: calc(100% + 14px);
    transform: translateX(-50%) translateY(-5px);
  }
  .mp:hover .mp-card-below {
    transform: translateX(-50%) translateY(0);
  }

  .mp-cat {
    display: block;
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 5px;
  }
  .mp-name {
    font-family: "Nunito", sans-serif;
    font-weight: 900;
    font-size: 0.9rem;
    color: #fff;
    line-height: 1.3;
    margin-bottom: 4px;
  }
  .mp-meta {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.38);
    margin-bottom: 8px;
  }
  .mp-avs {
    display: flex;
    gap: 4px;
  }
  .mp-av {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.58rem;
    font-weight: 800;
    color: #fff;
    border: 1.5px solid rgba(255, 255, 255, 0.15);
  }

  /* Filter bar */
  .mm-fbar {
    position: absolute;
    bottom: 14px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    gap: 4px;
    align-items: center;
    background: rgba(6, 10, 22, 0.88);
    backdrop-filter: blur(18px);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 100px;
    padding: 5px 7px;
    white-space: nowrap;
  }
  .mm-chip {
    font-size: 0.76rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.38);
    padding: 5px 13px;
    border-radius: 100px;
    cursor: pointer;
    border: none;
    background: transparent;
    font-family: "DM Sans", sans-serif;
    transition:
      color 0.18s,
      background 0.18s;
  }
  .mm-chip:hover {
    color: rgba(255, 255, 255, 0.8);
    background: rgba(255, 255, 255, 0.06);
  }
  .mm-chip-on {
    background: #7c3aed !important;
    color: #fff !important;
  }

  /* HIW Steps */
  .hiw-steps {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .hiw-step {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }
  .step-num {
    font-family: "Space Grotesk", sans-serif;
    font-weight: 800;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--accent);
    background: rgba(124, 58, 237, 0.1);
    border-radius: 100px;
    padding: 5px 12px;
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 3px;
  }
  .step-title {
    font-family: "Nunito", sans-serif;
    font-weight: 900;
    font-size: 1.1rem;
    color: var(--text-primary);
    margin-bottom: 4px;
  }
  .step-kicker {
    font-size: 0.85rem;
    font-style: italic;
    color: var(--accent);
    margin-bottom: 8px;
  }
  .step-body {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.75;
  }

  /* ── Section 4: Profiles (vertical phone screens) ── */
  .profiles-wrap {
    display: grid;
    grid-template-columns: 1fr;
    gap: 60px 28px;
    max-width: 360px;
    margin: 0 auto;
    perspective: 2200px;
  }
  @media (min-width: 900px) {
    .profiles-wrap {
      grid-template-columns: repeat(3, 1fr);
      max-width: 1080px;
      gap: 32px;
      align-items: center;
    }
  }

  /* Device */
  .phone {
    position: relative;
    width: 100%;
    max-width: 340px;
    margin: 0 auto;
    border-radius: 50px;
    padding: 9px;
    background: linear-gradient(160deg, #2c2540 0%, #181122 55%, #221a33 100%);
    box-shadow:
      0 60px 110px -36px rgba(60, 30, 110, 0.55),
      0 26px 50px -28px rgba(0, 0, 0, 0.4),
      inset 0 0 0 1.5px rgba(255, 255, 255, 0.08),
      inset 0 2px 3px rgba(255, 255, 255, 0.14);
    transition:
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.5s ease;
    will-change: transform;
  }
  @media (min-width: 900px) {
    .pc-2 {
      margin-top: -26px;
      z-index: 3;
    }
    .pc-2 .phone-glow {
      opacity: 0.95;
    }
    .phone:hover {
      transform: translateY(-14px) scale(1.03);
      box-shadow:
        0 80px 130px -38px rgba(60, 30, 110, 0.6),
        0 30px 60px -26px rgba(0, 0, 0, 0.45),
        inset 0 0 0 1.5px rgba(255, 255, 255, 0.1);
      z-index: 5;
    }
  }

  .phone-glow {
    position: absolute;
    inset: 8%;
    z-index: -1;
    border-radius: 50%;
    background: radial-gradient(circle, var(--pc), transparent 68%);
    filter: blur(46px);
    opacity: 0.55;
    transition: opacity 0.5s ease;
  }
  .phone:hover .phone-glow {
    opacity: 0.95;
  }

  .phone-screen {
    position: relative;
    height: 100%;
    background: radial-gradient(
      140% 60% at 50% 0%,
      color-mix(in srgb, var(--pc) 7%, #ffffff) 0%,
      #fbfaff 46%
    );
    border-radius: 42px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: inset 0 0 0 1px rgba(20, 12, 40, 0.06);
  }
  /* Dynamic-island */
  .phone-screen::before {
    content: "";
    position: absolute;
    top: 11px;
    left: 50%;
    transform: translateX(-50%);
    width: 78px;
    height: 18px;
    background: #14101f;
    border-radius: 100px;
    z-index: 30;
  }

  /* Status bar */
  .ps-status {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 11px 22px 5px;
    color: #2a2435;
  }
  .ps-time {
    font-family: "Nunito", sans-serif;
    font-weight: 800;
    font-size: 0.78rem;
    letter-spacing: -0.02em;
  }
  .ps-status-ic {
    display: flex;
    align-items: center;
    gap: 5px;
    color: #2a2435;
  }

  /* Cover */
  .ps-cover {
    position: relative;
    height: 104px;
    margin: 4px 10px 0;
    border-radius: 22px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .ps-cover-grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--pc-from) 0%, var(--pc) 100%);
  }
  .ps-cover-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      rgba(255, 255, 255, 0.22) 1.2px,
      transparent 1.2px
    );
    background-size: 13px 13px;
    mask-image: linear-gradient(120deg, #000 30%, transparent 90%);
    -webkit-mask-image: linear-gradient(120deg, #000 30%, transparent 90%);
  }
  .ps-live {
    position: absolute;
    top: 10px;
    left: 10px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: rgba(10, 8, 20, 0.32);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 100px;
    padding: 3px 9px;
    font-family: "Nunito", sans-serif;
    font-weight: 800;
